{
  "coc.preferences.formatOnSaveFiletypes": ["css", "markdown","php", "sass", "pug", "jade", "js", "styl"],


  // explorer
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": true,
  "explorer.keyMappings.global": {
    "<cr>": ["expandable?", "expand", "open"],
    "v": "open:vsplit"
  }

}
